{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.ai/schemas/local-credentials-map.schema.json",
  "title": "Agentlas Local Credentials Map",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "projectName", "projectRoot", "envFiles", "secretDirs", "entries"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "agentlas-local-credential-store" },
    "projectName": { "type": "string", "minLength": 1 },
    "projectRoot": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "envFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "secretDirs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "provider", "env", "localFiles", "owner", "valueMaterialized"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "env": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
            "uniqueItems": true
          },
          "localFiles": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "owner": { "type": "string", "minLength": 1 },
          "valueMaterialized": { "type": "boolean" },
          "storage": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "requiredFor": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "lastVerified": { "type": ["string", "null"] },
          "staleCheck": { "type": ["string", "null"] },
          "updatedAt": { "type": "string" }
        }
      }
    }
  }
}
