{
  "schemaVersion": "1.0",
  "projectId": "agentlas-core-engine-meta-agent",
  "purpose": "Keep the three-agent meta-agent team focused on single-agent creation, team creation, and Agentlas packaging.",
  "nodes": [
    { "id": "user-request", "kind": "input", "owner": "AGENTS.md" },
    { "id": "single-agent-creator", "kind": "mode", "owner": "10-single-agent-builder" },
    { "id": "team-builder", "kind": "mode", "owner": "20-multi-agent-team-builder" },
    { "id": "agentlas-packager", "kind": "mode", "owner": "30-agentlas-packager" },
    { "id": "agentlas-contracts", "kind": "architecture", "owner": "30-agentlas-packager" },
    { "id": "runtime-adapters", "kind": "adapter", "owner": "30-agentlas-packager" },
    { "id": "ontology-runtime", "kind": "runtime", "owner": "30-agentlas-packager" },
    { "id": "memory-architecture", "kind": "memory", "owner": "30-agentlas-packager" },
    { "id": "release-check", "kind": "verification", "owner": "30-agentlas-packager" }
  ],
  "edges": [
    { "from": "user-request", "to": "single-agent-creator", "reason": "one worker package" },
    { "from": "user-request", "to": "team-builder", "reason": "multi-role team package" },
    { "from": "user-request", "to": "agentlas-packager", "reason": "existing agent or distribution packaging" },
    { "from": "single-agent-creator", "to": "agentlas-contracts", "reason": "single agents still ship Agentlas contracts" },
    { "from": "team-builder", "to": "agentlas-contracts", "reason": "teams require full operating-system architecture" },
    { "from": "agentlas-packager", "to": "runtime-adapters", "reason": "packaged output must run across requested runtimes" },
    { "from": "runtime-adapters", "to": "ontology-runtime", "reason": "local-first source archive, search, graph, memory bridge, and working-memory runtime" },
    { "from": "ontology-runtime", "to": "memory-architecture", "reason": "GraphRAG can create candidate tickets and scoped hot-cache entries" },
    { "from": "agentlas-packager", "to": "release-check", "reason": "public and local packages require verification" }
  ],
  "taskBiases": [
    {
      "id": "single-not-team-by-default",
      "rule": "Use Single Agent Builder unless the user asks for a team, roster, HQ, gates, or multi-role ownership.",
      "appliesTo": ["single-agent-creator"]
    },
    {
      "id": "team-means-operating-system",
      "rule": "Team Builder must include orchestrator/HQ, PM Soul, Memory Curator, Policy Gate, eval, QA, handoffs, memory, and runtime adapters.",
      "appliesTo": ["team-builder"]
    },
    {
      "id": "package-existing-work",
      "rule": "Use Agentlas Packager for agents or teams already made locally, in another runtime, or in another repo.",
      "appliesTo": ["agentlas-packager"]
    },
    {
      "id": "adapter-is-thin",
      "rule": "Keep runtime-specific files as adapters over the canonical AGENTS.md core.",
      "appliesTo": ["codex", "claude", "gemini", "cursor"]
    },
    {
      "id": "verify-before-release",
      "rule": "Run package, plugin, and public-safety checks before claiming release readiness.",
      "appliesTo": ["publish", "plugin", "installer"]
    }
  ],
  "conceptCoverage": {
    "threeAgentMetaTeam": true,
    "singleAgentBuilder": true,
    "multiAgentTeamBuilder": true,
    "agentlasPackager": true,
    "selfEvolvingSingleAgent": true,
    "memoryArchitecture": true,
    "productionOntologyRuntime": true,
    "allLlmRuntimeArchitecture": true,
    "publicPluginPackaging": true,
    "terminalInstaller": true
  }
}
